<title>لعبة اونو - UNO</title>
<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;700;900&family=Baloo+Bhaijaan+2:wght@400;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<style>
:root{--bg-dark:#091a10;--bg-felt:#1a472a;--card-red:#E74C3C;--card-blue:#2980B9;--card-green:#27AE60;--card-yellow:#F1C40F;--gold:#FFD700;--text:#E8E8E8;--text-muted:#6a8a6e;--cw:clamp(46px,7vw,70px);--ch:clamp(67px,10.2vw,102px);--cw-sm:clamp(24px,3.6vw,38px);--ch-sm:clamp(35px,5.4vw,55px);--safe-t:env(safe-area-inset-top,0px);--safe-b:env(safe-area-inset-bottom,0px);--safe-l:env(safe-area-inset-left,0px);--safe-r:env(safe-area-inset-right,0px)}
*{margin:0;padding:0;box-sizing:border-box}
html,body{width:100%;height:100%;overflow:hidden;position:fixed;inset:0;font-family:'Cairo',sans-serif;background:var(--bg-dark);color:var(--text);-webkit-tap-highlight-color:transparent;-webkit-touch-callout:none;user-select:none}
body{background:radial-gradient(ellipse at center,var(--bg-felt) 0%,var(--bg-dark) 70%,#050d08 100%)}

/* زر ملء الشاشة */
#fs-btn{position:fixed;bottom:calc(var(--safe-b) + 6px);left:calc(var(--safe-l) + 6px);z-index:999;width:36px;height:36px;border-radius:50%;border:1px solid rgba(255,215,0,.3);background:rgba(0,0,0,.5);color:var(--gold);font-size:14px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .2s;backdrop-filter:blur(4px)}
#fs-btn:hover{background:rgba(255,215,0,.15);transform:scale(1.1)}

/* شاشة البداية */
#splash{position:fixed;inset:0;z-index:1000;display:flex;align-items:center;justify-content:center;background:radial-gradient(ellipse at center,#1e5631 0%,#0d2818 50%,#091a10 100%);cursor:pointer;animation:splashIn .5s ease-out}
@keyframes splashIn{from{opacity:0}to{opacity:1}}
#splash .inner{text-align:center;animation:splashPulse 2s ease-in-out infinite}
@keyframes splashPulse{0%,100%{transform:scale(1)}50%{transform:scale(1.03)}}
#splash .logo{font-family:'Baloo Bhaijaan 2',cursive;font-size:clamp(80px,20vw,160px);font-weight:800;background:linear-gradient(135deg,var(--card-red),var(--card-yellow),var(--card-green),var(--card-blue));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;line-height:1;filter:drop-shadow(0 0 40px rgba(255,215,0,.3))}
#splash .tap{font-size:clamp(13px,2.5vw,18px);color:var(--gold);margin-top:12px;animation:tapBlink 1.5s ease-in-out infinite}
@keyframes tapBlink{0%,100%{opacity:.5}50%{opacity:1}}

#pregame{position:fixed;inset:0;display:none;flex-direction:column;align-items:center;justify-content:flex-start;z-index:100;background:radial-gradient(ellipse at center,#1e5631 0%,#0d2818 50%,#091a10 100%);overflow-y:auto;overflow-x:hidden;padding:calc(var(--safe-t) + 12px) calc(var(--safe-r) + 10px) calc(var(--safe-b) + 20px) calc(var(--safe-l) + 10px)}
#pregame::before{content:'';position:fixed;inset:0;background:url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none'%3E%3Cg fill='%23ffffff' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");opacity:.5;pointer-events:none}
.pg-content{position:relative;z-index:1;text-align:center;max-width:95vw;width:100%}
.uno-title{font-family:'Baloo Bhaijaan 2',cursive;font-size:clamp(50px,11vw,100px);font-weight:800;background:linear-gradient(135deg,var(--card-red),var(--card-yellow),var(--card-green),var(--card-blue));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;line-height:1;filter:drop-shadow(0 0 25px rgba(255,215,0,.2));animation:pulse 3s ease-in-out infinite}
@keyframes pulse{0%,100%{filter:drop-shadow(0 0 25px rgba(255,215,0,.2))}50%{filter:drop-shadow(0 0 40px rgba(255,215,0,.4))}}
.subtitle{font-size:clamp(10px,1.8vw,14px);color:var(--text-muted);margin-top:-3px;margin-bottom:12px;letter-spacing:2px}
.pg-section{margin-bottom:10px}
.pg-section>label,.pg-section>h3{display:block;font-size:clamp(11px,1.8vw,14px);color:var(--gold);margin-bottom:4px;font-weight:700}
.name-input{padding:7px 10px;border-radius:8px;border:2px solid rgba(255,215,0,.3);background:rgba(0,0,0,.35);color:#fff;font-size:clamp(12px,2vw,16px);font-family:'Cairo';text-align:center;width:min(220px,68vw)}
.name-input:focus{outline:none;border-color:var(--gold)}
.name-input::placeholder{color:var(--text-muted);font-size:clamp(9px,1.5vw,12px)}
.opt-row{display:flex;gap:5px;justify-content:center;flex-wrap:wrap}
.opt-btn{padding:7px 12px;border-radius:7px;border:2px solid rgba(255,255,255,.1);background:rgba(0,0,0,.2);cursor:pointer;transition:all .2s;font-family:'Cairo';font-size:clamp(11px,1.8vw,13px);font-weight:700;color:var(--text);min-width:38px}
.opt-btn:hover{border-color:var(--gold)}
.opt-btn.sel{border-color:var(--gold);background:rgba(255,215,0,.1);color:var(--gold)}
.start-btns{display:flex;gap:7px;justify-content:center;flex-wrap:wrap;margin-bottom:12px}
.start-btn{padding:9px 16px;border:none;border-radius:9px;font-family:'Cairo';font-size:clamp(11px,2vw,14px);font-weight:700;cursor:pointer;transition:all .2s;display:flex;align-items:center;gap:5px}
.start-btn:hover{transform:scale(1.03)}
.start-btn.comp{background:linear-gradient(135deg,var(--card-green),#1a8a3a);color:#fff}
.start-btn.wifi{background:linear-gradient(135deg,var(--card-blue),#1a5a8a);color:#fff}
.cards-guide{margin-top:4px;text-align:center;max-width:min(560px,88vw);margin-left:auto;margin-right:auto}
.cards-guide h3{font-size:clamp(12px,2vw,15px);color:var(--gold);margin-bottom:6px}
.guide-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(min(200px,100%),1fr));gap:5px}
.guide-item{display:flex;align-items:center;gap:6px;padding:5px 7px;border-radius:7px;background:rgba(0,0,0,.2);border:1px solid rgba(255,255,255,.04)}
.mini-card{width:34px;height:49px;border-radius:4px;display:flex;align-items:center;justify-content:center;font-family:'Baloo Bhaijaan 2',cursive;font-weight:800;font-size:13px;flex-shrink:0;color:#fff;text-shadow:1px 1px 2px rgba(0,0,0,.5);position:relative;overflow:hidden;border:2px solid rgba(255,255,255,.2);box-shadow:0 2px 4px rgba(0,0,0,.3)}
.mini-card::before{content:'';position:absolute;top:12%;left:8%;width:84%;height:76%;background:rgba(255,255,255,.12);border-radius:50%/45%;transform:rotate(-15deg);pointer-events:none}
.mini-card .mc-val{position:relative;z-index:1;line-height:1}
.mini-card.mc-red{background:linear-gradient(145deg,#ff5e52,#c0392b)}.mini-card.mc-blue{background:linear-gradient(145deg,#3da8f5,#1a6daa)}.mini-card.mc-green{background:linear-gradient(145deg,#3dd679,#1a8a3a)}.mini-card.mc-yellow{background:linear-gradient(145deg,#ffe066,#d4a800);color:#333;text-shadow:none}
.mini-card.mc-wild{background:linear-gradient(145deg,#2c2c54,#1a1a2e);border-color:rgba(255,215,0,.3)}
.mini-card.mc-wild::after{content:'';position:absolute;top:15%;left:15%;width:70%;height:70%;background:conic-gradient(var(--card-red) 0deg,var(--card-yellow) 90deg,var(--card-green) 180deg,var(--card-blue) 270deg,var(--card-red) 360deg);border-radius:50%;opacity:.4;pointer-events:none}
.gi-text{font-size:clamp(8px,1.4vw,10px);color:var(--text);line-height:1.3;text-align:right}
.gi-text strong{color:var(--gold)}

#room-panel{display:none;margin-top:8px;padding:12px;border-radius:9px;background:rgba(0,0,0,.4);border:1px solid rgba(255,255,255,.1);min-width:min(260px,82vw);animation:fadeUp .3s ease-out}
@keyframes fadeUp{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}
#room-panel h3{margin-bottom:5px;font-size:clamp(11px,1.8vw,14px);color:var(--gold)}
.room-actions{display:flex;gap:5px;margin-bottom:5px;flex-wrap:wrap}
.room-actions button,.room-input button{padding:5px 9px;border:none;border-radius:5px;font-family:'Cairo';font-size:clamp(9px,1.5vw,11px);font-weight:700;cursor:pointer}
.btn-create{background:linear-gradient(135deg,var(--card-green),#1a8a3a);color:#fff}
.btn-join{background:linear-gradient(135deg,var(--card-blue),#1a5a8a);color:#fff}
.room-input{display:flex;gap:4px;margin-top:4px}
.room-input input{flex:1;padding:5px;border-radius:5px;border:2px solid rgba(255,255,255,.15);background:rgba(0,0,0,.3);color:#fff;font-size:12px;text-align:center;letter-spacing:4px;font-family:'Baloo Bhaijaan 2'}
.room-input input:focus{outline:none;border-color:var(--gold)}
.room-input button{background:var(--gold);color:#000}
#room-info{margin-top:5px;padding:6px;border-radius:5px;background:rgba(255,215,0,.06);border:1px solid rgba(255,215,0,.15);text-align:center}
.room-code{font-family:'Baloo Bhaijaan 2';font-size:clamp(20px,4.5vw,32px);font-weight:800;letter-spacing:6px;color:var(--gold);margin:3px 0}
.players-list{margin-top:3px;text-align:right}
.players-list div{padding:1px 4px;border-radius:3px;margin:1px 0;background:rgba(255,255,255,.05);font-size:9px}
.btn-start-room{margin-top:4px;padding:6px 14px;border:none;border-radius:6px;background:linear-gradient(135deg,var(--gold),#e6a800);color:#000;font-family:'Cairo';font-size:12px;font-weight:700;cursor:pointer}
.btn-back{margin-top:4px;padding:3px 8px;border:1px solid rgba(255,255,255,.2);border-radius:4px;background:transparent;color:var(--text-muted);font-family:'Cairo';cursor:pointer;font-size:9px}
.room-status{font-size:clamp(9px,1.4vw,11px);color:var(--text-muted);margin-top:3px}
.room-status i{color:var(--card-green)}

#game-screen{display:none;position:fixed;inset:0;z-index:50;padding:var(--safe-t) var(--safe-r) var(--safe-b) var(--safe-l)}
.game-table{display:grid;grid-template-areas:"top top top""left center right""bottom bottom bottom";grid-template-columns:clamp(40px,8vw,120px) 1fr clamp(40px,8vw,120px);grid-template-rows:clamp(42px,8dvh,88px) 1fr clamp(80px,16dvh,150px);height:100%;width:100%}
.player-area{display:flex;align-items:center;justify-content:center;gap:1px;padding:2px;position:relative;overflow:hidden}
.player-area.top{grid-area:top;flex-direction:column;gap:1px}
.player-area.left{grid-area:left;flex-direction:column}
.player-area.right{grid-area:right;flex-direction:column}
.player-area.bottom{grid-area:bottom;flex-direction:column;padding:2px 4px;overflow-x:auto;overflow-y:hidden}
.player-area.hidden{display:none!important}
.player-info{display:flex;align-items:center;gap:3px;padding:2px 4px;border-radius:4px;background:rgba(0,0,0,.35);border:2px solid transparent;transition:all .3s;white-space:nowrap}
.player-info.active{border-color:var(--gold);box-shadow:0 0 8px rgba(255,215,0,.3);animation:glow 1.5s ease-in-out infinite}
@keyframes glow{0%,100%{box-shadow:0 0 8px rgba(255,215,0,.3)}50%{box-shadow:0 0 16px rgba(255,215,0,.5)}}
.player-info .name{font-weight:700;font-size:clamp(7px,1.2vw,10px);max-width:55px;overflow:hidden;text-overflow:ellipsis}
.player-info .card-count{background:rgba(255,255,255,.1);padding:0 3px;border-radius:2px;font-size:clamp(6px,1vw,8px);font-weight:700}
.player-cards{display:flex;gap:1px;justify-content:center;flex-wrap:nowrap}
.player-area.bottom .player-cards{flex-wrap:nowrap;justify-content:center;padding:1px 0}
.player-area.left .player-cards,.player-area.right .player-cards{flex-direction:column;align-items:center}
.center-area{grid-area:center;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:clamp(2px,.8dvh,7px);position:relative}
.piles{display:flex;gap:clamp(5px,1.5vw,16px);align-items:center}
.draw-pile{position:relative}
.draw-pile .card-back-stack{position:absolute;top:1px;left:1px}
.discard-pile{position:relative}
.center-info{display:flex;gap:6px;align-items:center}
.color-indicator{width:clamp(20px,3vw,32px);height:clamp(20px,3vw,32px);border-radius:50%;border:2px solid rgba(255,255,255,.5);transition:all .3s}
.direction-indicator{font-size:clamp(11px,2vw,18px);color:var(--gold);transition:transform .5s}
.direction-indicator.ccw{transform:scaleX(-1)}
.game-msg{font-size:clamp(8px,1.4vw,12px);font-weight:700;color:var(--gold);min-height:12px;text-align:center;max-width:80vw;line-height:1.2}
.card{width:var(--cw);height:var(--ch);border-radius:clamp(4px,.7vw,8px);position:relative;display:inline-flex;align-items:center;justify-content:center;cursor:default;transition:transform .2s,box-shadow .2s;border:2px solid rgba(255,255,255,.2);font-family:'Baloo Bhaijaan 2',cursive;font-weight:800;color:#fff;text-shadow:1px 1px 2px rgba(0,0,0,.6);box-shadow:0 1px 4px rgba(0,0,0,.4);flex-shrink:0}
.card::before{content:'';position:absolute;top:12%;left:8%;width:84%;height:76%;background:rgba(255,255,255,.13);border-radius:50%/45%;transform:rotate(-15deg);pointer-events:none}
.card.red{background:linear-gradient(145deg,#ff5e52,#c0392b)}.card.blue{background:linear-gradient(145deg,#3da8f5,#1a6daa)}.card.green{background:linear-gradient(145deg,#3dd679,#1a8a3a)}.card.yellow{background:linear-gradient(145deg,#ffe066,#d4a800);color:#333;text-shadow:none}
.card.wild{background:linear-gradient(145deg,#2c2c54,#1a1a2e);border-color:rgba(255,215,0,.3)}
.card.wild::after{content:'';position:absolute;top:15%;left:15%;width:70%;height:70%;background:conic-gradient(var(--card-red) 0deg,var(--card-yellow) 90deg,var(--card-green) 180deg,var(--card-blue) 270deg,var(--card-red) 360deg);border-radius:50%;opacity:.4;pointer-events:none}
.card .corner{position:absolute;font-size:clamp(4px,.7vw,7px);z-index:1;line-height:1}
.card .corner.tr{top:1px;right:2px}.card .corner.bl{bottom:1px;left:2px}
.card .center-val{font-size:clamp(11px,2.5vw,20px);z-index:1;line-height:1}
.card .center-val.sm{font-size:clamp(8px,1.6vw,14px)}.card .center-val.xs{font-size:clamp(6px,1.1vw,11px)}
.card.playable{cursor:pointer;border-color:rgba(255,215,0,.6);animation:pg 1s ease-in-out infinite alternate}
.card.playable:hover{transform:translateY(-6px) scale(1.04);box-shadow:0 3px 12px rgba(255,215,0,.3);z-index:10}
@keyframes pg{from{box-shadow:0 1px 4px rgba(0,0,0,.4)}to{box-shadow:0 1px 8px rgba(255,215,0,.2)}}
.card.stackable{cursor:pointer;border-color:rgba(255,80,80,.7);animation:sg .8s ease-in-out infinite alternate}
.card.stackable:hover{transform:translateY(-6px) scale(1.04);z-index:10}
@keyframes sg{from{box-shadow:0 1px 4px rgba(0,0,0,.4)}to{box-shadow:0 1px 8px rgba(255,80,80,.3)}}
.card-back{width:var(--cw);height:var(--ch);border-radius:clamp(4px,.7vw,8px);background:linear-gradient(145deg,#2c2c54,#1a1a2e);border:2px solid rgba(255,255,255,.15);display:inline-flex;align-items:center;justify-content:center;box-shadow:0 1px 4px rgba(0,0,0,.4);flex-shrink:0;position:relative;overflow:hidden}
.card-back::before{content:'';position:absolute;top:15%;left:10%;width:80%;height:70%;background:rgba(231,76,60,.2);border-radius:50%/45%;transform:rotate(-15deg)}
.card-back span{font-family:'Baloo Bhaijaan 2';font-weight:800;font-size:clamp(5px,.9vw,9px);color:var(--card-red);z-index:1;transform:rotate(-20deg)}
.card-sm{--cw:var(--cw-sm);--ch:var(--ch-sm);border-radius:3px}
.card-sm .corner{font-size:clamp(2px,.4vw,4px)}.card-sm .center-val{font-size:clamp(6px,1.1vw,10px)}.card-sm::before{display:none}
.card-back-sm{width:var(--cw-sm);height:var(--ch-sm);border-radius:3px}.card-back-sm span{font-size:clamp(3px,.5vw,5px)}
.draw-penalty-btn{width:var(--cw);height:var(--ch);border-radius:clamp(4px,.7vw,8px);background:linear-gradient(145deg,#4a1a1a,#2a0a0a);border:3px dashed var(--card-red);display:inline-flex;align-items:center;justify-content:center;flex-direction:column;cursor:pointer;flex-shrink:0;animation:penP 1s ease-in-out infinite alternate}
.draw-penalty-btn:hover{transform:scale(1.02)}
.draw-penalty-btn .pn{font-family:'Baloo Bhaijaan 2';font-size:clamp(12px,2.2vw,20px);font-weight:800;color:var(--card-red)}
.draw-penalty-btn .pt{font-size:clamp(5px,.8vw,7px);color:var(--text-muted)}
@keyframes penP{from{box-shadow:0 0 4px rgba(231,76,60,.2)}to{box-shadow:0 0 10px rgba(231,76,60,.4)}}
#uno-btn{display:none;position:fixed;bottom:calc(var(--safe-b) + clamp(90px,17dvh,155px));left:50%;transform:translateX(-50%);padding:6px 18px;border:none;border-radius:8px;background:linear-gradient(135deg,var(--card-red),#c0392b);color:#fff;font-family:'Baloo Bhaijaan 2';font-size:clamp(13px,2.3vw,17px);font-weight:800;cursor:pointer;z-index:60;animation:unoP .5s ease-in-out infinite alternate;box-shadow:0 2px 12px rgba(231,76,60,.5)}
@keyframes unoP{from{transform:translateX(-50%) scale(1)}to{transform:translateX(-50%) scale(1.06)}}
#menu-btn{position:fixed;top:calc(var(--safe-t) + 4px);left:calc(var(--safe-l) + 4px);padding:2px 5px;border:1px solid rgba(255,255,255,.2);border-radius:4px;background:rgba(0,0,0,.4);color:var(--text-muted);font-family:'Cairo';font-size:8px;cursor:pointer;z-index:60}
.modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.7);z-index:200;align-items:center;justify-content:center;padding:var(--safe-t) var(--safe-r) var(--safe-b) var(--safe-l)}
.modal{background:linear-gradient(145deg,#1e3a2a,#0d2818);border:2px solid rgba(255,215,0,.2);border-radius:10px;padding:clamp(10px,2vw,18px);text-align:center;min-width:min(200px,75vw)}
.modal h2{margin-bottom:7px;font-size:clamp(11px,1.8vw,15px);color:var(--gold)}
.color-btns{display:grid;grid-template-columns:1fr 1fr;gap:4px}
.color-btn{padding:clamp(5px,1.3vw,9px);border:none;border-radius:6px;font-family:'Cairo';font-size:clamp(10px,1.6vw,13px);font-weight:700;color:#fff;cursor:pointer;border:2px solid transparent}
.color-btn:hover{border-color:#fff}
.color-btn.c-red{background:var(--card-red)}.color-btn.c-blue{background:var(--card-blue)}.color-btn.c-green{background:var(--card-green)}.color-btn.c-yellow{background:var(--card-yellow);color:#333}
.player-btns{display:flex;flex-direction:column;gap:4px}
.player-btn{padding:6px 8px;border:2px solid rgba(255,255,255,.15);border-radius:6px;background:rgba(0,0,0,.3);color:var(--text);font-family:'Cairo';font-size:clamp(9px,1.4vw,11px);font-weight:700;cursor:pointer}
.player-btn:hover{border-color:var(--gold);color:var(--gold)}
#toast-container{position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);z-index:300;display:flex;flex-direction:column;align-items:center;gap:2px;pointer-events:none}
.toast{padding:4px 10px;border-radius:6px;background:rgba(0,0,0,.88);color:#fff;font-weight:700;font-size:clamp(8px,1.3vw,11px);opacity:0;transform:scale(.8);transition:all .3s;backdrop-filter:blur(4px);border:1px solid rgba(255,255,255,.1);white-space:nowrap}
.toast.show{opacity:1;transform:scale(1)}.toast.warn{border-color:var(--card-red);color:var(--card-red)}.toast.success{border-color:var(--card-green);color:var(--card-green)}
.winner-name{font-size:clamp(16px,3.5vw,26px);font-weight:900;color:var(--gold);margin:5px 0;font-family:'Baloo Bhaijaan 2'}
.end-btns{display:flex;gap:4px;justify-content:center;margin-top:6px;flex-wrap:wrap}
.end-btn{padding:5px 10px;border:none;border-radius:6px;font-family:'Cairo';font-size:clamp(9px,1.4vw,11px);font-weight:700;cursor:pointer}
.end-btn.primary{background:linear-gradient(135deg,var(--gold),#e6a800);color:#000}
.end-btn.secondary{background:rgba(255,255,255,.1);color:var(--text);border:1px solid rgba(255,255,255,.2)}
#music-toggle{position:fixed;top:calc(var(--safe-t) + 4px);right:calc(var(--safe-r) + 4px);width:28px;height:28px;border-radius:50%;border:1px solid rgba(255,255,255,.2);background:rgba(0,0,0,.4);color:var(--text-muted);font-size:10px;cursor:pointer;z-index:200;display:flex;align-items:center;justify-content:center}
#music-toggle:hover{border-color:var(--gold);color:var(--gold)}#music-toggle.playing{color:var(--gold);border-color:var(--gold)}
.floating-cards{position:fixed;inset:0;overflow:hidden;pointer-events:none;z-index:0}
.float-card{position:absolute;border-radius:3px;opacity:.04;animation:floatC linear infinite}
@keyframes floatC{0%{transform:translateY(110vh) rotate(0)}100%{transform:translateY(-60px) rotate(360deg)}}
@media(max-width:360px){.game-table{grid-template-columns:clamp(24px,6vw,40px) 1fr clamp(24px,6vw,40px);grid-template-rows:clamp(32px,6dvh,42px) 1fr clamp(60px,13dvh,95px)}}
@media(prefers-reduced-motion:reduce){*{animation-duration:.01ms!important;transition-duration:.01ms!important}}
</style>
</head>
<body>
<button id="fs-btn" onclick="toggleFS()" title="ملء الشاشة"><i class="fas fa-expand"></i></button>
<button id="music-toggle" onclick="toggleMusic()"><i class="fas fa-music"></i></button>

<!-- شاشة البداية - نقرة للدخول -->
<div id="splash" onclick="enterApp()">
  <div class="inner">
    <div class="logo">UNO</div>
    <div class="tap"><i class="fas fa-hand-pointer"></i> اضغط للعب</div>
  </div>
</div>

<div id="pregame"><div class="floating-cards" id="floating-bg"></div><div class="pg-content">
<div class="uno-title">UNO</div><div class="subtitle">العبة الكلاسيكية الشهيرة</div>
<div class="pg-section"><label><i class="fas fa-user"></i> اسمك</label><input type="text" class="name-input" id="player-name" placeholder="اسمك هنا..." maxlength="12"></div>
<div class="pg-section"><h3><i class="fas fa-users"></i> عدد اللاعبين</h3><div class="opt-row" id="np-row"></div></div>
<div class="pg-section"><h3><i class="fas fa-gamepad"></i> وضع اللعب</h3><div class="opt-row" id="gm-row"></div></div>
<div class="start-btns"><button class="start-btn comp" onclick="startComputer()"><i class="fas fa-robot"></i> العب مع الكمبيوتر</button><button class="start-btn wifi" onclick="showWifiPanel()"><i class="fas fa-wifi"></i> لعب لاسلكي</button></div>
<div id="room-panel">
<div id="room-create-section"><h3><i class="fas fa-wifi"></i> لعب لاسلكي</h3><div class="room-actions"><button class="btn-create" onclick="createRoom()"><i class="fas fa-plus"></i> إنشاء</button><button class="btn-join" onclick="document.getElementById('join-ui').style.display='flex'"><i class="fas fa-sign-in-alt"></i> انضمام</button></div><div id="join-ui" style="display:none;flex-direction:column;gap:4px;margin-top:4px"><div class="room-input"><input type="text" id="join-code" maxlength="5" placeholder="رمز الغرفة" oninput="this.value=this.value.replace(/[^0-9]/g,'')"><button onclick="joinRoom()">انضمام</button></div></div></div>
<div id="room-info" style="display:none"><div>رمز الغرفة:</div><div class="room-code" id="display-code"></div><div class="room-status" id="room-status"><i class="fas fa-circle"></i> بانتظار اللاعبين...</div><div class="players-list" id="lobby-players"></div><button class="btn-start-room" id="btn-start-lobby" onclick="startWifiGame()">ابدأ اللعبة</button></div>
<button class="btn-back" onclick="hideRoomPanel()"><i class="fas fa-arrow-right"></i> رجوع</button>
</div>
<div class="cards-guide"><h3><i class="fas fa-info-circle"></i> شرح البطاقات</h3><div class="guide-grid" id="guide-grid"></div></div>
</div></div>

<div id="game-screen"><div class="game-table">
<div class="player-area top" id="area-top"><div class="player-info" id="info-top"><span class="name" id="name-top">-</span><span class="card-count" id="count-top">7</span></div><div class="player-cards" id="cards-top"></div></div>
<div class="player-area left" id="area-left"><div class="player-info" id="info-left"><span class="name" id="name-left">-</span><span class="card-count" id="count-left">7</span></div><div class="player-cards" id="cards-left"></div></div>
<div class="center-area"><div class="game-msg" id="game-msg"></div><div class="piles"><div class="draw-pile"><div class="card-back card-back-stack"></div><div class="card-back"><span>UNO</span></div></div><div class="discard-pile" id="discard-pile"></div></div><div class="center-info"><div class="color-indicator" id="color-indicator"></div><div class="direction-indicator" id="direction-indicator"><i class="fas fa-rotate-right"></i></div></div></div>
<div class="player-area right" id="area-right"><div class="player-info" id="info-right"><span class="name" id="name-right">-</span><span class="card-count" id="count-right">7</span></div><div class="player-cards" id="cards-right"></div></div>
<div class="player-area bottom" id="area-bottom"><div class="player-info" id="info-bottom"><span class="name" id="name-bottom">-</span><span class="card-count" id="count-bottom">7</span></div><div class="player-cards" id="cards-bottom"></div></div>
</div><button id="uno-btn" onclick="onUnoClick()">UNO!</button><button id="menu-btn" onclick="backToMenu()"><i class="fas fa-home"></i></button></div>

<div class="modal-overlay" id="color-modal"><div class="modal"><h2><i class="fas fa-palette"></i> اختر اللون</h2><div class="color-btns"><button class="color-btn c-red" onclick="pickColor('red')">احمر</button><button class="color-btn c-blue" onclick="pickColor('blue')">ازرق</button><button class="color-btn c-green" onclick="pickColor('green')">اخضر</button><button class="color-btn c-yellow" onclick="pickColor('yellow')">اصفر</button></div></div></div>
<div class="modal-overlay" id="player-modal"><div class="modal"><h2 id="player-modal-title">اختر</h2><div class="player-btns" id="player-btns"></div></div></div>
<div class="modal-overlay" id="end-modal"><div class="modal"><h2><i class="fas fa-trophy"></i> انتهت اللعبة</h2><div class="winner-name" id="winner-name"></div><div class="end-btns"><button class="end-btn primary" onclick="restartGame()">مرة أخرى</button><button class="end-btn secondary" onclick="backToMenu()">القائمة</button></div></div></div>
<div id="toast-container"></div>
<script>
/* ========== ملء الشاشة ========== */
let isFS=false;
function tryFS(){
  const el=document.documentElement;
  if(el.requestFullscreen)el.requestFullscreen().catch(()=>{});
  else if(el.webkitRequestFullscreen)el.webkitRequestFullscreen();
  else if(el.msRequestFullscreen)el.msRequestFullscreen();
  // iOS Safari
  else if(document.body.webkitEnterFullscreen)document.body.webkitEnterFullscreen();
  else if(window.navigator.standalone===undefined){
    // محاولة لـ iOS
    const v=document.createElement('video');v.setAttribute('playsinline','');v.style.cssText='position:fixed;top:0;left:0;width:1px;height:1px;opacity:0';
    document.body.appendChild(v);v.play().then(()=>{v.webkitEnterFullscreen()}).catch(()=>{});setTimeout(()=>v.remove(),1000);
  }
}
function exitFS(){
  if(document.exitFullscreen)document.exitFullscreen().catch(()=>{});
  else if(document.webkitExitFullscreen)document.webkitExitFullscreen();
  else if(document.msExitFullscreen)document.msExitFullscreen();
}
function toggleFS(){
  if(isFS){exitFS();isFS=false;document.getElementById('fs-btn').innerHTML='<i class="fas fa-expand"></i>'}
  else{tryFS();isFS=true;document.getElementById('fs-btn').innerHTML='<i class="fas fa-compress"></i>'}
}
document.addEventListener('fullscreenchange',()=>{isFS=!!document.fullscreenElement;document.getElementById('fs-btn').innerHTML=isFS?'<i class="fas fa-compress"></i>':'<i class="fas fa-expand"></i>'});
document.addEventListener('webkitfullscreenchange',()=>{isFS=!!document.webkitFullscreenElement;document.getElementById('fs-btn').innerHTML=isFS?'<i class="fas fa-compress"></i>':'<i class="fas fa-expand"></i>'});

/* ========== شاشة البداية ========== */
function enterApp(){
  // محاولة ملء الشاشة عند أول تفاعل
  tryFS();
  document.getElementById('splash').style.display='none';
  document.getElementById('pregame').style.display='flex';
  initAudio(); // تفعيل الصوت يحتاج تفاعل أيضاً
}

/* ========== ثوابت ========== */
const COLORS=['red','blue','green','yellow'],COLOR_NAMES={red:'احمر',blue:'ازرق',green:'اخضر',yellow:'اصفر'};
const TYPE_SYM={number:v=>v,skip:'⊘',reverse:'⟲',draw2:'+2',draw3:'+3',draw4:'+4',draw6:'+6',draw8:'+8',wild:'★',redirect:'↩',skip_choice:'✋'};
const DRAW_TYPES=['draw2','draw3','draw4','draw6','draw8'],DRAW_AMT={draw2:2,draw3:3,draw4:4,draw6:6,draw8:8},WILD_TYPES=['wild','draw3','draw4','draw6','draw8','redirect','skip_choice'];
let uid=0,selectedNumPlayers=4,selectedGameMode='normal';

(function(){const nr=document.getElementById('np-row');[2,3,4].forEach(n=>{const b=document.createElement('button');b.className='opt-btn'+(n===4?' sel':'');b.textContent=n;b.onclick=()=>{selectedNumPlayers=n;nr.querySelectorAll('.opt-btn').forEach(x=>x.classList.toggle('sel',+x.textContent===n))};nr.appendChild(b)});const mr=document.getElementById('gm-row');[{v:'normal',t:'عادي'},{v:'07',t:'0 و 7'}].forEach(m=>{const b=document.createElement('button');b.className='opt-btn'+(m.v==='normal'?' sel':'');b.textContent=m.t;b.onclick=()=>{selectedGameMode=m.v;mr.querySelectorAll('.opt-btn').forEach(x=>x.classList.toggle('sel',x.textContent===m.t))};mr.appendChild(b)})})();
(function(){const g=document.getElementById('guide-grid');if(!g)return;[{c:'mc-red',v:'0-9',t:'أرقام',d:'بلون أو رقم مطابق'},{c:'mc-red',v:'⊘',t:'إيقاف',d:'يوقف التالي'},{c:'mc-green',v:'⟲',t:'عكس',d:'يعكس الاتجاه'},{c:'mc-yellow',v:'+2',t:'+2',d:'يسحب 2 أو يكدس'},{c:'mc-wild',v:'★',t:'تغيير لون',d:'اختر لون'},{c:'mc-wild',v:'+4',t:'+4',d:'لون + يسحب 4'},{c:'mc-wild',v:'+3',t:'+3',d:'لون + يسحب 3'},{c:'mc-wild',v:'+6',t:'+6',d:'لون + يسحب 6'},{c:'mc-wild',v:'+8',t:'+8',d:'لون + يسحب 8'},{c:'mc-wild',v:'↩',t:'تحويل',d:'لاعب يسحب 2 بدلاً منك'},{c:'mc-wild',v:'✋',t:'إيقاف اختياري',d:'اختر لاعب لإيقافه'},{c:'mc-red',v:'0',t:'0 (0و7)',d:'تبديل حسب الاتجاه'},{c:'mc-blue',v:'7',t:'7 (0و7)',d:'تبديل مع من تشاء'}].forEach(i=>{const d=document.createElement('div');d.className='guide-item';d.innerHTML=`<div class="mini-card ${i.c}"><span class="mc-val">${i.v}</span></div><div class="gi-text"><strong>${i.t}:</strong> ${i.d}</div>`;g.appendChild(d)})})();

let G={mode:'computer',gameMode:'normal',numPlayers:4,players:[],deck:[],discard:[],currentPlayer:0,direction:1,currentColor:null,gameOver:false,unoTimer:null,unoNeeded:false,myId:0,started:false,busy:false,pendingDraw:0,pendingDrawType:null};
let colorResolve=null,playerResolve=null,channel=null,roomCode='',isHost=false,wifiPlayers=[],isWifiGuest=false;

/* موسيقى */
let audioCtx=null,musicPlaying=false,musicNodes=[];
function initAudio(){if(audioCtx)return;audioCtx=new(window.AudioContext||window.webkitAudioContext)()}
function toggleMusic(){initAudio();if(audioCtx.state==='suspended')audioCtx.resume();if(musicPlaying){stopMusic();return}musicPlaying=true;document.getElementById('music-toggle').classList.add('playing');document.getElementById('music-toggle').innerHTML='<i class="fas fa-volume-up"></i>';playMelody()}
function stopMusic(){musicPlaying=false;document.getElementById('music-toggle').classList.remove('playing');document.getElementById('music-toggle').innerHTML='<i class="fas fa-music"></i>';musicNodes.forEach(n=>{try{n.stop()}catch(e){}});musicNodes=[]}
function playMelody(){if(!musicPlaying||!audioCtx)return;const sc=[261.63,293.66,329.63,349.23,392,440,493.88,523.25],pt=[0,2,4,5,4,2,0,2,4,5,7,5,4,2,0],dr=[.4,.4,.4,.6,.4,.4,.8,.4,.4,.4,.6,.4,.4,.4,.8];let t=audioCtx.currentTime+.1;for(let i=0;i<pt.length;i++){const o=audioCtx.createOscillator(),g=audioCtx.createGain();o.type='sine';o.frequency.value=sc[pt[i]];g.gain.setValueAtTime(0,t);g.gain.linearRampToValueAtTime(.04,t+.05);g.gain.linearRampToValueAtTime(.02,t+dr[i]*.7);g.gain.linearRampToValueAtTime(0,t+dr[i]);o.connect(g);g.connect(audioCtx.destination);o.start(t);o.stop(t+dr[i]+.05);musicNodes.push(o);t+=dr[i]}setTimeout(()=>{if(musicPlaying)playMelody()},dr.reduce((a,b)=>a+b,0)*1000+500)}
function playSFX(f,d,tp='sine',v=.04){if(!audioCtx)return;const o=audioCtx.createOscillator(),g=audioCtx.createGain();o.type=tp;o.frequency.value=f;g.gain.setValueAtTime(0,audioCtx.currentTime);g.gain.linearRampToValueAtTime(v,audioCtx.currentTime+.02);g.gain.linearRampToValueAtTime(0,audioCtx.currentTime+d);o.connect(g);g.connect(audioCtx.destination);o.start();o.stop(audioCtx.currentTime+d+.05)}

function makeCard(type,color,value){return{id:uid++,type,color,value:value??null}}
function createDeck(){let d=[];for(const c of COLORS){d.push(makeCard('number',c,0));for(let n=1;n<=9;n++){d.push(makeCard('number',c,n));d.push(makeCard('number',c,n))}for(let i=0;i<3;i++){d.push(makeCard('skip',c));d.push(makeCard('reverse',c));d.push(makeCard('draw2',c))}}for(let i=0;i<5;i++){d.push(makeCard('wild',null));d.push(makeCard('draw4',null))}for(let i=0;i<3;i++){d.push(makeCard('draw3',null));d.push(makeCard('draw6',null));d.push(makeCard('draw8',null));d.push(makeCard('redirect',null));d.push(makeCard('skip_choice',null))}return d}
function shuffle(a){for(let i=a.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[a[i],a[j]]=[a[j],a[i]]}return a}
function getSlotMap(){const n=G.numPlayers,me=G.myId,opp=[];for(let i=1;i<n;i++)opp.push((me+i)%n);if(n===2)return{bottom:me,top:opp[0],left:-1,right:-1};if(n===3)return{bottom:me,right:opp[0],top:opp[1],left:-1};return{bottom:me,right:opp[0],top:opp[1],left:opp[2]}}
function startComputer(){const name=document.getElementById('player-name').value.trim()||'لاعب';G.mode='computer';G.myId=0;G.numPlayers=selectedNumPlayers;G.gameMode=selectedGameMode;isWifiGuest=false;const names=[name],humans=[true];for(let i=1;i<G.numPlayers;i++){names.push('الكمبيوتر '+i);humans.push(false)}initAndStart(names,humans)}
function initAndStart(names,humans){uid=0;G.numPlayers=names.length;G.deck=shuffle(createDeck());G.discard=[];G.currentPlayer=0;G.direction=1;G.gameOver=false;G.unoNeeded=false;G.busy=false;G.pendingDraw=0;G.pendingDrawType=null;G.players=names.map((n,i)=>({name:n,hand:[],isHuman:humans[i],skipped:false}));for(let i=0;i<7;i++)for(let p=0;p<G.numPlayers;p++){const c=G.deck.pop();if(c)G.players[p].hand.push(c)}let first=G.deck.pop(),safe=0;while(first&&WILD_TYPES.includes(first.type)&&safe<300){G.deck.unshift(first);shuffle(G.deck);first=G.deck.pop();safe++}if(!first)return;G.discard.push(first);G.currentColor=first.color;if(first.type==='skip')G.players[0].skipped=true;else if(first.type==='reverse')G.direction=-1;else if(DRAW_TYPES.includes(first.type)){G.pendingDraw=DRAW_AMT[first.type];G.pendingDrawType=first.type}G.started=true;document.getElementById('pregame').style.display='none';document.getElementById('game-screen').style.display='block';applySlotVisibility();renderAll();beginTurn()}
function applySlotVisibility(){const s=getSlotMap();['top','left','right'].forEach(p=>document.getElementById('area-'+p).classList.toggle('hidden',s[p]===-1))}
function beginTurn(){if(G.gameOver)return;const pIdx=G.currentPlayer,p=G.players[pIdx];if(p.skipped){p.skipped=false;showToast(`${p.name} تم تخطيه`);setTimeout(()=>advanceTurn(),400);return}if(G.pendingDraw>0){const st=p.hand.filter(c=>c.type===G.pendingDrawType);if(st.length>0){if(p.isHuman){setMsg(`عليك +${G.pendingDraw}! ضع ${TYPE_SYM[G.pendingDrawType]} أو اسحب`);renderAll()}else{G.busy=true;setTimeout(()=>{G.busy=false;playCard(pIdx,st[0].id)},500+Math.random()*300)}}else{const dr=drawFromDeck(G.pendingDraw);p.hand.push(...dr);showToast(`${p.name} يسحب ${G.pendingDraw}!`);G.pendingDraw=0;G.pendingDrawType=null;renderAll();broadcastState();setTimeout(()=>advanceTurn(),400)}return}if(p.isHuman){const pl=getPlayable(p.hand);setMsg(pl.length>0?'دورك! اختر بطاقة':'لا بطاقة - اضغط للسحب');renderAll()}else{G.busy=true;setTimeout(()=>{G.busy=false;aiTurn()},500+Math.random()*300)}}
function advanceTurn(){if(G.gameOver)return;G.currentPlayer=(G.currentPlayer+G.direction+G.numPlayers)%G.numPlayers;renderAll();broadcastState();setTimeout(()=>beginTurn(),150)}
function canPlay(c){if(WILD_TYPES.includes(c.type))return true;if(c.color===G.currentColor)return true;const t=topCard();if(!t)return false;if(c.type==='number'&&t.type==='number'&&c.value===t.value)return true;if(c.type!=='number'&&c.type===t.type)return true;return false}
function getPlayable(h){return h.filter(c=>canPlay(c))}
function topCard(){return G.discard.length>0?G.discard[G.discard.length-1]:null}
function nextIdx(f){return(f+G.direction+G.numPlayers)%G.numPlayers}
async function playCard(pIdx,cardId){if(G.gameOver||G.busy)return;G.busy=true;const p=G.players[pIdx],ci=p.hand.findIndex(c=>c.id===cardId);if(ci===-1){G.busy=false;return}const card=p.hand.splice(ci,1)[0];G.discard.push(card);playSFX(600,.08);if(p.hand.length===1){if(pIdx===G.myId)showUnoBtn();else{if(Math.random()<.85)showToast(`${p.name} UNO!`,'success');else{showToast(`${p.name} نسى UNO! +2`,'warn');p.hand.push(...drawFromDeck(2))}}}if(p.hand.length===0){G.gameOver=true;renderAll();broadcastState();setTimeout(()=>showEnd(pIdx),400);G.busy=false;return}await applyEffect(card,pIdx);if(G.gameOver){G.busy=false;return}G.busy=false;advanceTurn()}
async function applyEffect(card,pIdx){const isWild=WILD_TYPES.includes(card.type);if(isWild){let color;if(G.players[pIdx].isHuman)color=await chooseColorUI();else color=aiPickColor(pIdx);G.currentColor=color}else{G.currentColor=card.color}if(G.gameMode==='07'){if(card.type==='number'&&card.value===0){const hands=G.players.map(p=>[...p.hand]);for(let i=0;i<G.numPlayers;i++)G.players[i].hand=hands[nextIdx(i)];showToast('0! تبديل!');renderAll();return}if(card.type==='number'&&card.value===7){let target;if(G.players[pIdx].isHuman)target=await choosePlayerUI(pIdx,'اختر لاعبًا لتبديل الأوراق');else target=aiPickTarget(pIdx);const tmp=[...G.players[pIdx].hand];G.players[pIdx].hand=[...G.players[target].hand];G.players[target].hand=tmp;showToast('7! تبادل!');renderAll();return}}switch(card.type){case'skip':{const ni=nextIdx(pIdx);G.players[ni].skipped=true;showToast(`${G.players[ni].name} إيقاف!`);break}case'reverse':if(G.numPlayers===2){G.players[nextIdx(pIdx)].skipped=true;showToast('عكس = إيقاف!')}else{G.direction*=-1;showToast('عكس الاتجاه!')}break;case'draw2':case'draw3':case'draw4':case'draw6':case'draw8':{const amt=DRAW_AMT[card.type];if(G.pendingDraw>0&&G.pendingDrawType===card.type){G.pendingDraw+=amt;showToast(`تكديس! +${G.pendingDraw}`)}else{G.pendingDraw=amt;G.pendingDrawType=card.type;showToast(`+${amt}!`)}break}case'redirect':{let target;if(G.players[pIdx].isHuman)target=await choosePlayerUI(pIdx,'اختر لاعبًا يسحب 2 بدلاً منك');else target=aiPickTarget(pIdx);G.players[target].hand.push(...drawFromDeck(2));G.players[target].skipped=true;showToast(`${G.players[target].name} يسحب 2!`);break}case'skip_choice':{let target;if(G.players[pIdx].isHuman)target=await choosePlayerUI(pIdx,'اختر لاعبًا لإيقافه');else target=aiPickTarget(pIdx);G.players[target].skipped=true;showToast(`${G.players[target].name} إيقاف!`);break}}renderAll()}
function drawFromDeck(count){const drawn=[];for(let i=0;i<count;i++){if(G.deck.length===0)reshuffleDeck();if(G.deck.length>0)drawn.push(G.deck.pop())}return drawn}
function reshuffleDeck(){if(G.discard.length<=1)return;const t=G.discard.pop();G.deck=shuffle([...G.discard]);G.discard=[t]}
function onCardClick(cardId){if(G.gameOver||G.busy)return;if(isWifiGuest){channel.postMessage({type:'action',action:'play',cardId,playerId:G.myId});return}if(G.currentPlayer!==G.myId)return;const p=G.players[G.myId],card=p.hand.find(c=>c.id===cardId);if(!card)return;if(G.pendingDraw>0){if(card.type===G.pendingDrawType){playCard(G.myId,cardId);return}showToast('ضع بطاقة من نفس نوع السحب أو اسحب!','warn');return}if(!canPlay(card)){showToast('لا يمكنك لعب هذه البطاقة!','warn');return}playCard(G.myId,cardId)}
async function humanDraw(){if(G.gameOver||G.busy)return;if(isWifiGuest){channel.postMessage({type:'action',action:'draw',playerId:G.myId});return}const pIdx=G.myId;if(G.pendingDraw>0){G.busy=true;const p=G.players[pIdx];const dr=drawFromDeck(G.pendingDraw);p.hand.push(...dr);showToast(`سحبت ${G.pendingDraw} عقاب!`,'warn');G.pendingDraw=0;G.pendingDrawType=null;renderAll();broadcastState();G.busy=false;advanceTurn();return}G.busy=true;const p=G.players[pIdx];let cnt=0;while(true){const dc=drawFromDeck(1);if(dc.length===0)break;p.hand.push(dc[0]);cnt++;renderAll();broadcastState();if(canPlay(dc[0])){showToast(`سحبت ${cnt} ولعبت!`,'success');G.busy=false;await sleep(200);await playCard(pIdx,dc[0].id);return}showToast(`سحبت... اللون: ${COLOR_NAMES[G.currentColor]}`);await sleep(250)}showToast(`سحبت ${cnt}`,'warn');G.busy=false;advanceTurn()}
async function aiTurn(){if(G.gameOver)return;const pIdx=G.currentPlayer,p=G.players[pIdx],pl=getPlayable(p.hand);if(pl.length>0){await playCard(pIdx,aiBestCard(pl,pIdx).id)}else{let cnt=0;while(true){const dc=drawFromDeck(1);if(dc.length===0)break;p.hand.push(dc[0]);cnt++;renderAll();broadcastState();if(canPlay(dc[0])){showToast(`${p.name} سحب ${cnt} ولعب!`);await sleep(200);await playCard(pIdx,dc[0].id);return}await sleep(120)}showToast(`${p.name} سحب ${cnt}`);advanceTurn()}}
function aiBestCard(pl,pIdx){if(G.gameMode==='07'){const s7=pl.filter(c=>c.type==='number'&&c.value===7),s0=pl.filter(c=>c.type==='number'&&c.value===0),mn=Math.min(...G.players.filter((_,i)=>i!==pIdx).map(p=>p.hand.length));if(s7.length>0&&G.players[pIdx].hand.length>mn)return s7[0];if(s0.length>0&&G.players[pIdx].hand.length>3)return s0[0]}const act=pl.filter(c=>['skip','reverse','draw2'].includes(c.type)),num=pl.filter(c=>c.type==='number'),wild=pl.filter(c=>WILD_TYPES.includes(c.type));if(act.length>0)return act[Math.floor(Math.random()*act.length)];if(num.length>0)return num[Math.floor(Math.random()*num.length)];return wild[Math.floor(Math.random()*wild.length)]}
function aiPickColor(pIdx){const cnt={red:0,blue:0,green:0,yellow:0};G.players[pIdx].hand.forEach(c=>{if(c.color&&cnt[c.color]!==undefined)cnt[c.color]++});let b='red',m=-1;for(const[c,n]of Object.entries(cnt))if(n>m){m=n;b=c}return b}
function aiPickTarget(pIdx){let t=-1,min=999;G.players.forEach((p,i)=>{if(i!==pIdx&&p.hand.length<min){min=p.hand.length;t=i}});return t>=0?t:(pIdx+1)%G.numPlayers}
function showUnoBtn(){G.unoNeeded=true;const btn=document.getElementById('uno-btn');btn.style.display='block';clearTimeout(G.unoTimer);G.unoTimer=setTimeout(()=>{btn.style.display='none';G.unoNeeded=false;if(G.players[G.myId].hand.length===1){showToast('نسيت UNO! +2','warn');G.players[G.myId].hand.push(...drawFromDeck(2));renderAll();broadcastState()}},3000)}
function onUnoClick(){clearTimeout(G.unoTimer);document.getElementById('uno-btn').style.display='none';G.unoNeeded=false;showToast('UNO!','success');playSFX(880,.06)}
function chooseColorUI(){return new Promise(r=>{document.getElementById('color-modal').style.display='flex';colorResolve=r})}
function pickColor(c){document.getElementById('color-modal').style.display='none';if(colorResolve){if(isWifiGuest&&G.currentPlayer===G.myId)channel.postMessage({type:'colorChoice',color:c});colorResolve(c);colorResolve=null}}
function choosePlayerUI(excludeIdx,title){return new Promise(r=>{document.getElementById('player-modal-title').textContent=title||'اختر اللاعب';const ct=document.getElementById('player-btns');ct.innerHTML='';G.players.forEach((p,i)=>{if(i!==excludeIdx){const b=document.createElement('button');b.className='player-btn';b.textContent=`${p.name} (${p.hand.length})`;b.onclick=()=>{document.getElementById('player-modal').style.display='none';if(isWifiGuest&&G.currentPlayer===G.myId)channel.postMessage({type:'playerChoice',targetIdx:i});r(i);playerResolve=null};ct.appendChild(b)}});document.getElementById('player-modal').style.display='flex';playerResolve=r})}

function renderAll(){renderMyHand();renderOpponents();renderDiscard();renderColorInd();renderDir();renderTurnInd()}
function cSym(c){return c.type==='number'?c.value:(TYPE_SYM[c.type]||'?')}
function cCls(c){return c.color||'wild'}
function renderCardHTML(card,small,mode){const sym=cSym(card),cls=cCls(card),sz=small?'card-sm':'',mc=mode==='playable'?'playable':mode==='stackable'?'stackable':'',sl=String(sym).length,sc=sl>2?'xs':sl>1?'sm':'';return`<div class="card ${cls} ${sz} ${mc}" onclick="onCardClick(${card.id})"><span class="corner tr">${sym}</span><span class="center-val ${sc}">${sym}</span><span class="corner bl">${sym}</span></div>`}
function renderMyHand(){const el=document.getElementById('cards-bottom');if(!el)return;const p=G.players[G.myId];if(!p)return;const myTurn=G.currentPlayer===G.myId&&!G.busy;let html='';if(G.pendingDraw>0&&myTurn){const st=p.hand.filter(c=>c.type===G.pendingDrawType);p.hand.forEach(c=>{html+=renderCardHTML(c,false,st.some(s=>s.id===c.id)?'stackable':'')});html+=`<div class="draw-penalty-btn" onclick="humanDraw()"><span class="pn">+${G.pendingDraw}</span><span class="pt">اسحب</span></div>`}else if(myTurn){const pl=getPlayable(p.hand),pids=pl.map(c=>c.id);p.hand.forEach(c=>{html+=renderCardHTML(c,false,pids.includes(c.id)?'playable':'')});if(pids.length===0)html+=`<div class="draw-penalty-btn" onclick="humanDraw()" style="border-color:var(--gold)"><span class="pn" style="color:var(--gold)"><i class="fas fa-layer-group"></i></span><span class="pt">اسحب</span></div>`}else{p.hand.forEach(c=>{html+=renderCardHTML(c,false,'')})}el.innerHTML=html;document.getElementById('count-bottom').textContent=p.hand.length;document.getElementById('name-bottom').textContent=p.name}
function renderOpponents(){const s=getSlotMap();['top','left','right'].forEach(pos=>{const pIdx=s[pos];const el=document.getElementById('cards-'+pos),nameEl=document.getElementById('name-'+pos),countEl=document.getElementById('count-'+pos);if(pIdx===-1||!el||!G.players[pIdx]){if(el)el.innerHTML='';return}const p=G.players[pIdx];let h='';for(let j=0;j<p.hand.length;j++)h+='<div class="card-back card-back-sm"><span>U</span></div>';el.innerHTML=h;nameEl.textContent=p.name;countEl.textContent=p.hand.length})}
function renderDiscard(){const el=document.getElementById('discard-pile');if(!el)return;const top=topCard();el.innerHTML=top?renderCardHTML(top,false,''):''}
function renderColorInd(){const el=document.getElementById('color-indicator');if(!el)return;const c={red:'var(--card-red)',blue:'var(--card-blue)',green:'var(--card-green)',yellow:'var(--card-yellow)'};el.style.background=c[G.currentColor]||'#555';el.style.boxShadow=`0 0 8px ${c[G.currentColor]||'#555'}20`}
function renderDir(){const el=document.getElementById('direction-indicator');if(!el)return;el.className='direction-indicator'+(G.direction===-1?' ccw':'');el.innerHTML=G.direction===1?'<i class="fas fa-rotate-right"></i>':'<i class="fas fa-rotate-left"></i>'}
function renderTurnInd(){const s=getSlotMap();['bottom','top','left','right'].forEach(pos=>{const el=document.getElementById('info-'+pos);if(el)el.classList.toggle('active',s[pos]===G.currentPlayer)})}
function setMsg(t){const el=document.getElementById('game-msg');if(el)el.textContent=t}
function showToast(msg,type){const c=document.getElementById('toast-container'),t=document.createElement('div');t.className='toast'+(type==='warn'?' warn':type==='success'?' success':'');t.textContent=msg;c.appendChild(t);requestAnimationFrame(()=>t.classList.add('show'));setTimeout(()=>{t.classList.remove('show');setTimeout(()=>{if(t.parentNode)t.remove()},300)},1400)}
function showEnd(wi){document.getElementById('winner-name').textContent=G.players[wi].name+' فاز!';document.getElementById('end-modal').style.display='flex';createConfetti();playSFX(523,.08);playSFX(659,.08);playSFX(784,.1)}
function restartGame(){document.getElementById('end-modal').style.display='none';if(G.mode==='wifi'&&!isWifiGuest)startWifiGame();else startComputer()}
function backToMenu(){document.getElementById('game-screen').style.display='none';document.getElementById('end-modal').style.display='none';document.getElementById('pregame').style.display='flex';G.started=false;G.gameOver=true;isWifiGuest=false;if(channel){channel.close();channel=null}}
function createConfetti(){const cols=['#E74C3C','#2980B9','#27AE60','#F1C40F','#FFD700','#E91E63'];for(let i=0;i<25;i++){const c=document.createElement('div'),sz=3+Math.random()*4;c.style.cssText=`position:fixed;width:${sz}px;height:${sz}px;background:${cols[Math.floor(Math.random()*cols.length)]};border-radius:${Math.random()>.5?'50%':'2px'};top:-5px;left:${Math.random()*100}vw;z-index:400;pointer-events:none;opacity:.7;animation:confF ${1.5+Math.random()*2}s linear ${Math.random()}s forwards`;document.body.appendChild(c);setTimeout(()=>{if(c.parentNode)c.remove()},4000)}if(!document.getElementById('conf-s')){const s=document.createElement('style');s.id='conf-s';s.textContent='@keyframes confF{0%{transform:translateY(0) rotate(0);opacity:1}100%{transform:translateY(100vh) rotate(720deg);opacity:0}}';document.head.appendChild(s)}}
function createFloatingCards(){const ct=document.getElementById('floating-bg');if(!ct)return;const cols=['var(--card-red)','var(--card-blue)','var(--card-green)','var(--card-yellow)'];for(let i=0;i<4;i++){const c=document.createElement('div');c.className='float-card';c.style.cssText=`left:${Math.random()*100}%;background:${cols[i%4]};animation-duration:${7+Math.random()*8}s;animation-delay:${Math.random()*4}s;width:${18+Math.random()*15}px;height:${30+Math.random()*18}px`;ct.appendChild(c)}}

/* لاسلكي */
function showWifiPanel(){document.getElementById('room-panel').style.display='block';document.getElementById('room-create-section').style.display='block';document.getElementById('room-info').style.display='none';document.getElementById('join-ui').style.display='none'}
function hideRoomPanel(){document.getElementById('room-panel').style.display='none';if(channel){channel.close();channel=null}isWifiGuest=false}
function createRoom(){roomCode=String(Math.floor(10000+Math.random()*90000));isHost=true;isWifiGuest=false;const myName=document.getElementById('player-name').value.trim()||'المضيف';wifiPlayers=[{id:0,name:myName}];if(channel)channel.close();channel=new BroadcastChannel('uno-room-'+roomCode);channel.onmessage=onWifiMsg;document.getElementById('room-create-section').style.display='none';document.getElementById('room-info').style.display='block';document.getElementById('display-code').textContent=roomCode;renderLobby();showToast('تم إنشاء الغرفة','success')}
function joinRoom(){const code=document.getElementById('join-code').value.trim();if(code.length!==5){showToast('أدخل رمز 5 أرقام','warn');return}roomCode=code;isHost=false;isWifiGuest=true;const myName=document.getElementById('player-name').value.trim()||'لاعب';if(channel)channel.close();channel=new BroadcastChannel('uno-room-'+roomCode);channel.onmessage=onWifiMsg;channel.postMessage({type:'join',name:myName});document.getElementById('room-create-section').style.display='none';document.getElementById('room-info').style.display='block';document.getElementById('display-code').textContent=roomCode;document.getElementById('btn-start-lobby').style.display='none';document.getElementById('room-status').innerHTML='<i class="fas fa-spinner fa-spin"></i> جاري الانضمام...';renderLobby();showToast('تم إرسال طلب الانضمام','success')}
function onWifiMsg(e){const d=e.data;if(d.type==='join'&&isHost){const nid=wifiPlayers.length;wifiPlayers.push({id:nid,name:d.name||('لاعب '+nid)});channel.postMessage({type:'lobbySync',players:wifiPlayers});renderLobby();showToast(`${d.name} انضم!`,'success')}if(d.type==='lobbySync'&&!isHost){wifiPlayers=d.players;const myName=document.getElementById('player-name').value.trim()||'لاعب';G.myId=wifiPlayers.findIndex(p=>p.name===myName);if(G.myId<0)G.myId=wifiPlayers.length-1;document.getElementById('room-status').innerHTML='<i class="fas fa-circle"></i> متصل';renderLobby()}if(d.type==='gameStart'&&!isHost){G.myId=d.yourId;G.mode='wifi';G.gameMode=d.gameMode;isWifiGuest=true;loadFullState(d.state);document.getElementById('pregame').style.display='none';document.getElementById('game-screen').style.display='block';applySlotVisibility();renderAll();setMsg(G.currentPlayer===G.myId?'دورك!':`دور ${G.players[G.currentPlayer].name}...`)}if(d.type==='stateUpdate'&&!isHost){loadFullState(d.state);renderAll();if(G.currentPlayer===G.myId&&!G.busy){if(G.pendingDraw>0)setMsg(`عليك +${G.pendingDraw}!`);else{const pl=getPlayable(G.players[G.myId].hand);setMsg(pl.length>0?'دورك!':'اضغط للسحب')}}else setMsg(`دور ${G.players[G.currentPlayer].name}...`)}if(d.type==='action'&&isHost)handleGuestAction(d);if(d.type==='colorChoice'&&isHost&&colorResolve){colorResolve(d.color);colorResolve=null}if(d.type==='playerChoice'&&isHost&&playerResolve){playerResolve(d.targetIdx);playerResolve=null}}
function renderLobby(){const el=document.getElementById('lobby-players');if(!el)return;el.innerHTML=wifiPlayers.map((p,i)=>`<div><i class="fas fa-user" style="color:${i===0?'var(--card-green)':'var(--card-blue)'}"></i> ${p.name}${i===0?' (مضيف)':''}</div>`).join('');const btn=document.getElementById('btn-start-lobby');btn.style.display=isHost&&wifiPlayers.length>=2?'block':'none'}
function startWifiGame(){if(!isHost)return;G.mode='wifi';G.gameMode=selectedGameMode;G.numPlayers=selectedNumPlayers;const names=wifiPlayers.map(x=>x.name),humans=wifiPlayers.map(()=>true);while(names.length<G.numPlayers){names.push('الكمبيوتر '+(names.length+1));humans.push(false)}initAndStart(names,humans);for(let i=1;i<wifiPlayers.length;i++)channel.postMessage({type:'gameStart',yourId:i,gameMode:G.gameMode,state:getFullState()})}
function getFullState(){return{players:G.players.map(p=>({name:p.name,hand:p.hand,isHuman:p.isHuman,skipped:p.skipped})),deckCount:G.deck.length,discard:G.discard,currentPlayer:G.currentPlayer,direction:G.direction,currentColor:G.currentColor,gameOver:G.gameOver,pendingDraw:G.pendingDraw,pendingDrawType:G.pendingDrawType,numPlayers:G.numPlayers}}
function loadFullState(s){G.players=s.players.map(p=>({name:p.name,hand:p.hand,isHuman:p.isHuman,skipped:p.skipped}));G.deck=new Array(s.deckCount);G.discard=s.discard;G.currentPlayer=s.currentPlayer;G.direction=s.direction;G.currentColor=s.currentColor;G.gameOver=s.gameOver;G.pendingDraw=s.pendingDraw||0;G.pendingDrawType=s.pendingDrawType||null;G.numPlayers=s.numPlayers||4;G.started=true;G.busy=false}
function broadcastState(){if(G.mode==='wifi'&&isHost&&channel)channel.postMessage({type:'stateUpdate',state:getFullState()})}
async function handleGuestAction(d){if(G.gameOver||G.busy)return;const pIdx=d.playerId;if(pIdx!==G.currentPlayer)return;if(d.action==='play'){const card=G.players[pIdx].hand.find(c=>c.id===d.cardId);if(!card)return;if(G.pendingDraw>0&&card.type!==G.pendingDrawType)return;if(G.pendingDraw<=0&&!canPlay(card))return;await playCard(pIdx,d.cardId)}else if(d.action==='draw'){if(G.pendingDraw>0){G.busy=true;const p=G.players[pIdx];const dr=drawFromDeck(G.pendingDraw);p.hand.push(...dr);showToast(`${p.name} يسحب ${G.pendingDraw}!`,'warn');G.pendingDraw=0;G.pendingDrawType=null;renderAll();broadcastState();G.busy=false;advanceTurn()}else{G.busy=true;const p=G.players[pIdx];let cnt=0;while(true){const dc=drawFromDeck(1);if(dc.length===0)break;p.hand.push(dc[0]);cnt++;renderAll();broadcastState();if(canPlay(dc[0])){showToast(`${p.name} سحب ${cnt} ولعب!`);G.busy=false;await sleep(180);await playCard(pIdx,dc[0].id);return}await sleep(120)}showToast(`${p.name} سحب ${cnt}`);G.busy=false;advanceTurn()}}}
function sleep(ms){return new Promise(r=>setTimeout(r,ms))}
createFloatingCards();

/* منع التمرير والتكبير */
document.addEventListener('touchmove',e=>{if(e.touches.length>1)e.preventDefault()},{passive:false});
document.addEventListener('gesturestart',e=>e.preventDefault());
</script>
